    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Cut the paneer, red bell pepper, green bell pepper, and red onion into uniform 3cm pieces to ensure even cooking and easy skewering.",
        "structured": {
          "action": "CHOP",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "prep",
        "text": "In a large mixing bowl, whisk together the greek yogurt, mustard oil, ginger garlic paste, kashmiri chili powder, garam masala, ground coriander, turmeric, chaat masala, kasuri methi, lemon juice, and salt until smooth and vibrant red.",
        "structured": {
          "action": "MIX",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "prep",
        "text": "Add the chopped paneer and vegetables to the mixing bowl. Gently toss the ingredients until every piece is thickly coated in the yogurt marinade.",
        "structured": {
          "action": "FOLD",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "prep",
        "text": "Cover the bowl tightly and refrigerate to allow the spices to penetrate the paneer and vegetables. Marinate for at least 2 hours, or up to 24 hours for maximum flavor.",
        "structured": {
          "action": "MARINATE",
          "temperature": null,
          "duration": "PT2H",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "cook",
        "text": "Heat a grill or grill pan over medium-high heat until it reaches roughly 200°C/400°F. Lightly brush the grates with a high smoke point oil.",
        "structured": {
          "action": "PREHEAT",
          "temperature": {
            "celsius": 200,
            "fahrenheit": 392
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "assemble",
        "text": "Thread the marinated paneer, red onion, and bell peppers alternately onto the skewers, packing them snugly but not too tight to ensure heat circulates evenly.",
        "structured": {
          "action": "ASSEMBLE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": [
          "If using bamboo or wooden skewers, ensure they have been soaked in cold water for 30 minutes to prevent burning."
        ]
      },
      {
        "step_number": 7,
        "phase": "cook",
        "text": "Place the skewers on the hot grill. Cook, turning every 2 to 3 minutes, until the paneer develops a crisp, beautifully charred exterior and the vegetables are tender but still retain a slight bite.",
        "structured": {
          "action": "GRILL",
          "temperature": null,
          "duration": "PT10M",
          "doneness_cues": {
            "visual": "Blackened char marks on the paneer edges and slightly blistered pepper skins",
            "tactile": "Paneer feels firm but springy, vegetables yield slightly to pressure"
          }
        },
        "tips": []
      },
      {
        "step_number": 8,
        "phase": "finish",
        "text": "Transfer the hot skewers to a serving platter. Serve immediately while the paneer is soft and warm inside.",
        "structured": {
          "action": "SERVE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": [
          "Dust lightly with extra chaat masala and serve with a wedge of lemon and fresh mint chutney."
        ]
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Paneer breaks or crumbles while threading onto skewers or grilling",
        "likely_cause": "Paneer was too soft, cut too small, or handled roughly",
        "prevention": "Purchase firm block paneer rather than fresh soft paneer, and cut into generous 3cm cubes",
        "fix": "Remove from skewers and cook the pieces loosely in a flat pan as a stir-fry"
      },
      {
        "symptom": "Marinade drips off heavily during grilling",
        "likely_cause": "Yogurt contained too much whey or water",
        "prevention": "Use thick Greek yogurt or hang standard yogurt in cheesecloth for 2 hours before mixing",
        "fix": "Baste the skewers with any remaining thick marinade from the bottom of the bowl during the first few minutes of cooking"
      }
    ],
    "chef_notes": [
      "Mustard oil is traditional in tandoori marinades, providing a signature sharp, pungent flavor. If using raw mustard oil, heat it in a pan until it reaches its smoking point, then let it cool completely before adding to the marinade to remove its raw bitterness.",
      "Using Kashmiri chili powder is the secret to the bright, appetizing red color of authentic tikka without making the dish overwhelmingly spicy. Do not substitute with standard cayenne pepper unless you drastically reduce the quantity.",
      "Ensure your grill is thoroughly preheated before adding the skewers. A hot initial sear is crucial to prevent the paneer from sticking to the grates and to set the yogurt marinade quickly."
    ],
    "cultural_context": "Paneer Tikka is a widely loved vegetarian adaptation of Chicken Tikka, originating in the Punjab region of the Indian subcontinent. Traditionally cooked in a cylindrical clay oven called a tandoor, the intense heat of the charcoal creates a signature smoky flavor and external char that defines the dish. It is a staple at Indian celebrations and street food stalls alike.",
