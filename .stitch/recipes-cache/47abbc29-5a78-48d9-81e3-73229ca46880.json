    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Place the thawed peas in a fine mesh sieve and press out any excess moisture with a paper towel. The peas must be completely dry to prevent a watery dip.",
        "structured": {
          "action": "PAT_DRY",
          "temperature": null,
          "duration": "PT2M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "prep",
        "text": "Transfer the dried peas to a food processor and pulse until coarsely pureed. Alternatively, thoroughly crush them in a mixing bowl using a potato masher.",
        "structured": {
          "action": "PUREE",
          "temperature": null,
          "duration": "PT2M",
          "doneness_cues": {
            "visual": "Coarse, textured paste rather than a perfectly smooth puree",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "prep",
        "text": "In a mixing bowl, add the diced avocado. Gently crush with a fork until broken down but still slightly chunky.",
        "structured": {
          "action": "CRUSH",
          "temperature": null,
          "duration": "PT2M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "assemble",
        "text": "Add the pea puree to the crushed avocado. Fold in the finely diced red onion, minced jalapeno, and chopped fresh cilantro.",
        "structured": {
          "action": "FOLD",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "finish",
        "text": "Pour in the fresh lime juice, kosher salt, and ground cumin. Stir gently to combine. Taste and adjust seasoning with additional lime juice or salt if necessary.",
        "structured": {
