    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Preheat the oven to 200°C/400°F. Line a baking sheet with parchment paper to prevent sticking.",
        "structured": {
          "action": "PREHEAT",
          "temperature": {
            "celsius": 200,
            "fahrenheit": 392
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "prep",
        "text": "Place the frozen fish fingers on the prepared baking sheet. Sprinkle evenly with smoked paprika, ground cumin, and garlic powder, tossing gently so the spices adhere to the frosty coating.",
        "structured": {
          "action": "SEASON",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "cook",
        "text": "Bake in the preheated oven for 15 minutes, turning halfway through, until the exterior is golden and crispy, and the internal temperature reaches 74°C/165°F.",
        "structured": {
          "action": "BAKE",
          "temperature": {
            "celsius": 200,
            "fahrenheit": 392
          },
          "duration": "PT15M",
          "doneness_cues": {
            "visual": "golden brown and crispy crust",
            "tactile": "firm to the touch with bubbling juices"
          }
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "prep",
        "text": "While the fish fingers bake, combine the sour cream and fresh lime juice in a small bowl. Stir thoroughly to create a smooth, tangy crema.",
        "structured": {
          "action": "MIX",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "cook",
        "text": "Heat a dry frying pan over medium-high heat. Warm each flour tortilla for about 30 seconds per side until soft, pliable, and slightly charred at the edges.",
        "structured": {
          "action": "TOAST",
          "temperature": null,
          "duration": "PT4M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "assemble",
        "text": "Spread a generous spoonful of lime crema onto the center of each warm tortilla. Top with two spiced fish fingers, a heap of pickled red onions, and a sprinkle of fresh coriander. Serve immediately.",
        "structured": {
          "action": "ASSEMBLE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Tortillas crack or break when folded",
        "likely_cause": "Tortillas were not heated adequately or dried out during heating",
        "prevention": "Keep warmed tortillas wrapped in a slightly damp kitchen towel until the exact moment of assembly",
        "fix": "Cannot be fixed once broken, but can be eaten flat as a tostada"
      },
      {
        "symptom": "Fish fingers are soggy on the bottom",
        "likely_cause": "Oven was not fully preheated, or fish fingers were overcrowded on the tray",
        "prevention": "Ensure the oven is at full temperature before inserting the tray and leave space between each piece",
        "fix": "Return to the oven or air fryer for an additional 3 to 4 minutes"
      }
    ],
    "chef_notes": [
      "Using an air fryer instead of an oven will reduce cooking time to about 10 minutes and yield a superior, crispier exterior. Adjust temperature to 190 degrees Celsius.",
      "Applying the dry spices directly to the slightly frosty exterior of frozen fish fingers allows the moisture to act as a binder, helping the seasoning adhere without needing extra oil.",
      "To make quick pickled onions from scratch: thinly slice a red onion and submerge it in equal parts hot water and apple cider vinegar with a large pinch of salt and sugar. Let sit for at least 30 minutes before draining."
    ],
    "cultural_context": "This dish embraces the modern culinary trend of elevating humble, nostalgic convenience foods with vibrant, fresh accompaniments. It draws structural inspiration from Baja-style fish tacos, replacing labor-intensive battered white fish with highly accessible fish fingers for a rapid, weeknight-friendly meal.",
