    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Place the quinoa in a fine mesh sieve and rinse thoroughly under cold running water for at least 30 seconds to remove the bitter coating.",
        "structured": {
          "action": "RINSE",
          "temperature": null,
          "duration": "PT0H1M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "cook",
        "text": "In a medium saucepan, combine the rinsed quinoa, vegetable broth, 15ml olive oil, and 3g salt. Bring to a boil over medium-high heat at 100 degrees Celsius or 212 degrees Fahrenheit, then reduce the heat to low, cover, and simmer until the liquid is absorbed and the quinoa is tender.",
        "structured": {
          "action": "SIMMER",
          "temperature": {
            "celsius": 100,
            "fahrenheit": 212
          },
          "duration": "PT0H15M",
          "doneness_cues": {
            "visual": "Liquid is completely absorbed and quinoa germs present as tiny white spirals",
            "tactile": "Quinoa yields easily to a bite without hard centers"
          }
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "prep",
        "text": "Remove the quinoa from heat and let it rest covered for 5 minutes. Fluff with a fork and spread it on a baking sheet to cool completely.",
        "structured": {
          "action": "COOL",
          "temperature": null,
          "duration": "PT0H15M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "prep",
        "text": "While the quinoa cools, prepare the Mediterranean dressing by vigorously whisking together tahini, lemon juice, and cold water in a small bowl until smooth. Add a pinch of salt to taste.",
        "structured": {
          "action": "WHISK",
          "temperature": null,
          "duration": "PT0H2M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "prep",
        "text": "Prepare the Southwestern dressing by whisking together 30ml olive oil, lime juice, and ground cumin in a second small bowl.",
        "structured": {
          "action": "WHISK",
          "temperature": null,
          "duration": "PT0H2M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "prep",
        "text": "Prepare the Asian-inspired dressing by whisking together the tamari, toasted sesame oil, rice vinegar, and maple syrup in a third small bowl.",
        "structured": {
          "action": "WHISK",
          "temperature": null,
          "duration": "PT0H2M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 7,
        "phase": "assemble",
        "text": "Divide the cooled quinoa evenly among 6 meal prep containers, placing approximately 150g of cooked quinoa into each.",
        "structured": {
          "action": "MEASURE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 8,
        "phase": "assemble",
        "text": "Build two Mediterranean bowls by topping the quinoa with chickpeas, cucumber, cherry tomatoes, and kalamata olives. Pack the tahini dressing in separate small containers.",
        "structured": {
          "action": "PLATE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 9,
        "phase": "assemble",
        "text": "Build two Southwestern bowls by topping the quinoa with black beans, corn, and diced red bell pepper. Pack the lime-cumin dressing in separate small containers.",
        "structured": {
          "action": "PLATE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 10,
        "phase": "assemble",
        "text": "Build two Asian-inspired bowls by topping the quinoa with edamame, shredded carrots, and red cabbage. Pack the sesame-tamari dressing in separate small containers.",
        "structured": {
