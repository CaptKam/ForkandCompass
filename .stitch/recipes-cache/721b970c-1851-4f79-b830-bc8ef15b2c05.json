    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Preheat the oven to 200 degrees Celsius or 400 degrees Fahrenheit.",
        "structured": {
          "action": "PREHEAT",
          "temperature": {
            "celsius": 200,
            "fahrenheit": 392
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "prep",
        "text": "In a large mixing bowl, combine the carrots, sweet potato, red onion wedges, and chickpeas.",
        "structured": {
          "action": "MIX",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "prep",
        "text": "Drizzle the mixed vegetables and chickpeas with 30ml of olive oil, then add the ras el hanout, minced garlic, and salt. Toss thoroughly to coat.",
        "structured": {
          "action": "SEASON",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "cook",
        "text": "Spread the seasoned vegetables and chickpeas evenly onto a baking sheet. Roast in the preheated oven at 200 degrees Celsius or 400 degrees Fahrenheit for 20 minutes.",
        "structured": {
          "action": "ROAST",
          "temperature": {
            "celsius": 200,
            "fahrenheit": 392
          },
          "duration": "PT20M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "cook",
        "text": "Remove the baking sheet from the oven briefly, add the zucchini slices, toss everything gently, and return to the oven for another 15 minutes until all vegetables are tender and slightly caramelized.",
        "structured": {
          "action": "ROAST",
          "temperature": {
            "celsius": 200,
            "fahrenheit": 392
          },
          "duration": "PT15M",
          "doneness_cues": {
            "visual": "edges are browned and caramelized",
            "tactile": "vegetables are easily pierced with a fork"
          }
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "cook",
        "text": "While the vegetables finish roasting, pour the vegetable broth into a saucepan and bring to a boil over high heat.",
        "structured": {
          "action": "BOIL",
          "temperature": null,
          "duration": "PT5M",
          "doneness_cues": {
            "visual": "rapid, rolling bubbles",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 7,
        "phase": "cook",
        "text": "Remove the boiling broth from the heat. Stir in the dry couscous and the remaining 15ml of olive oil, then immediately cover the saucepan with a tight-fitting lid.",
        "structured": {
          "action": "STIR",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 8,
        "phase": "finish",
        "text": "Let the couscous steep undisturbed off the heat for 5 minutes.",
        "structured": {
          "action": "REST",
          "temperature": null,
          "duration": "PT5M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 9,
        "phase": "finish",
        "text": "Remove the lid from the saucepan and gently fluff the couscous with a fork to separate the individual grains.",
        "structured": {
          "action": "MIX",
          "temperature": null,
          "duration": null,
          "doneness_cues": {
            "visual": "light and distinct grains, no clumps",
            "tactile": null
          }
        },
        "tips": [
          "Always use a fork rather than a spoon to avoid mashing the delicate grains."
        ]
      },
      {
        "step_number": 10,
        "phase": "prep",
        "text": "In a small bowl, whisk the harissa paste with a tablespoon of warm water to loosen it into a drizzle-able sauce.",
        "structured": {
          "action": "WHISK",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 11,
        "phase": "assemble",
        "text": "Spread the fluffed couscous onto a large serving platter or divide among individual bowls. Top generously with the roasted vegetables and chickpeas.",
        "structured": {
          "action": "ASSEMBLE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 12,
        "phase": "finish",
        "text": "Drizzle the loosened harissa sauce over the top and scatter the freshly chopped parsley evenly across the dish.",
        "structured": {
          "action": "GARNISH",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Couscous is clumpy and mushy",
        "likely_cause": "Too much liquid or stirred too aggressively while hot",
        "prevention": "Measure liquid accurately and only use a fork to fluff",
        "fix": "Spread onto a flat baking sheet to cool slightly and gently break apart clumps with fingers"
      },
      {
        "symptom": "Vegetables are steaming instead of roasting",
        "likely_cause": "Baking sheet is overcrowded",
        "prevention": "Use two baking sheets if necessary to ensure vegetables are in a single layer with space between them",
        "fix": "Increase oven temperature by 10-15 degrees for the last few minutes or transfer half to another pan"
      },
      {
        "symptom": "Dish is overwhelmingly spicy",
        "likely_cause": "Harissa brand is particularly fiery",
        "prevention": "Taste the harissa before making the sauce and adjust quantities accordingly",
        "fix": "Serve with a side of plain yogurt or a squeeze of lemon juice to cut the heat"
      }
    ],
    "chef_notes": [
      "To build even more flavor, try toasting the dry couscous in a dry skillet for 2-3 minutes until fragrant before adding the boiling broth.",
      "Zucchini is added later in the roasting process because it contains more water and cooks much faster than dense root vegetables like sweet potato and carrots.",
      "Ras el hanout is a complex Moroccan spice blend. If you do not have it, a quick substitute can be made by mixing cumin, coriander, cinnamon, ginger, and a pinch of cayenne.",
      "Do not over-mix the couscous when fluffing. The mechanical action of a spoon will crush the semolina spheres, creating a dense paste."
    ],
    "cultural_context": "Couscous is deeply embedded in the culinary traditions of North Africa, particularly Morocco, where it is traditionally steamed multiple times in a couscoussier over a simmering stew. While this roasted vegetable variation is a quicker, modern adaptation suited for weeknight cooking, it honors authentic flavor profiles by pairing the staple grain with the aromatic warmth of ras el hanout and the fiery depth of harissa.",
