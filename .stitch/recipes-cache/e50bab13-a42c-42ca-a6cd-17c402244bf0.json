        "tips": []
      },
      {
        "step_number": 2,
        "phase": "cook",
        "text": "Seal the shaker and shake the contents vigorously without ice for 20 seconds to emulsify the egg white.",
        "structured": {
          "action": "SHAKE",
          "temperature": null,
          "duration": "PT20S",
          "doneness_cues": {
            "visual": "Mixture should appear frothy and pale.",
            "tactile": null
          }
        },
        "tips": [
          "This is called a dry shake and is essential for a thick foam."
        ]
      },
      {
        "step_number": 3,
        "phase": "cook",
        "text": "Add a handful of ice to the shaker and shake again for 15 seconds until the outside of the vessel is chilled.",
        "structured": {
          "action": "SHAKE",
          "temperature": null,
          "duration": "PT15S",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "finish",
        "text": "Strain the liquid through a Hawthorne strainer into a chilled Nick and Nora coupe glass.",
        "structured": {
