    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Preheat the oven to 160°C or 320°F. Line the bottom and sides of a 20cm springform pan with parchment paper.",
        "structured": {
          "action": "PREHEAT",
          "temperature": {
            "celsius": 160,
            "fahrenheit": 320
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "prep",
        "text": "Place the digestive biscuits in a food processor and pulse until fine crumbs form.",
        "structured": {
          "action": "CRUSH",
          "temperature": null,
          "duration": null,
          "doneness_cues": {
            "visual": "texture resembling fine sand",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "prep",
        "text": "Transfer the biscuit crumbs to a mixing bowl. Add the melted butter and green cardamom powder, stirring until the mixture is evenly moistened.",
        "structured": {
          "action": "MIX",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "assemble",
        "text": "Press the crumb mixture firmly and evenly into the bottom of the prepared springform pan using the back of a spoon or a flat-bottomed glass.",
        "structured": {
          "action": "SHAPE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "cook",
        "text": "Bake the crust at 160°C or 320°F for 10 minutes. Remove from the oven and let it cool completely.",
        "structured": {
          "action": "BAKE",
          "temperature": {
            "celsius": 160,
            "fahrenheit": 320
          },
          "duration": "PT10M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "prep",
        "text": "In the bowl of a stand mixer, beat the room temperature cream cheese on medium speed until perfectly smooth and free of lumps.",
        "structured": {
          "action": "BEAT",
          "temperature": null,
          "duration": null,
          "doneness_cues": {
            "visual": "completely smooth and creamy, no lumps visible",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 7,
        "phase": "prep",
        "text": "Add the sweetened condensed milk, heavy cream, cornstarch, rose water, and saffron-infused milk to the cream cheese. Beat on low speed just until combined, scraping down the sides of the bowl as needed.",
        "structured": {
          "action": "BLEND",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": [
          "Avoid overmixing at this stage to prevent incorporating too much air, which can cause cracking."
        ]
      },
      {
        "step_number": 8,
        "phase": "assemble",
        "text": "Arrange the drained, halved gulab jamun pieces evenly over the cooled biscuit crust, flat side down.",
        "structured": {
          "action": "ASSEMBLE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 9,
        "phase": "assemble",
        "text": "Gently pour the cheesecake batter over the gulab jamun pieces, spreading it into an even layer with a spatula.",
        "structured": {
          "action": "POUR",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 10,
        "phase": "cook",
        "text": "Bake at 160°C or 320°F for 45 to 55 minutes. The cheesecake is done when the edges are set but the center 5cm still has a slight wobble when gently shaken.",
        "structured": {
          "action": "BAKE",
          "temperature": {
            "celsius": 160,
            "fahrenheit": 320
          },
          "duration": "PT50M",
          "doneness_cues": {
            "visual": "edges puffed and set",
            "tactile": "center jiggles like gelatin when the pan is tapped"
          }
        },
        "tips": []
      },
      {
        "step_number": 11,
        "phase": "finish",
        "text": "Turn off the oven and prop the door slightly open. Leave the cheesecake in the oven to cool slowly for 1 hour.",
        "structured": {
          "action": "COOL",
          "temperature": null,
          "duration": "PT1H",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 12,
        "phase": "finish",
        "text": "Remove the cheesecake from the oven and transfer it to the refrigerator. Chill for at least 6 hours, or preferably overnight, until completely firm.",
        "structured": {
          "action": "CHILL",
          "temperature": null,
          "duration": "PT6H",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 13,
        "phase": "finish",
        "text": "Once fully chilled, carefully release the sides of the springform pan. Garnish the edges with chopped pistachios and dried edible rose petals before slicing.",
        "structured": {
          "action": "GARNISH",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Cheesecake surface cracks",
        "likely_cause": "Overmixing the batter incorporating excess air, or cooling the cheesecake too rapidly",
        "prevention": "Mix ingredients on low speed once condensed milk is added, and strictly adhere to the gradual oven cooling step",
        "fix": "Cosmetic only. Cover the top with an extra layer of sliced gulab jamuns, whipped cream, or extra pistachios before serving"
      },
      {
        "symptom": "Soggy biscuit crust",
        "likely_cause": "Excess syrup weeping from the gulab jamun during baking",
        "prevention": "Drain the gulab jamun pieces thoroughly on paper towels and squeeze very gently before placing them on the crust",
        "fix": "Cannot be fixed once baked"
      },
      {
        "symptom": "Cheesecake center is completely liquid",
        "likely_cause": "Oven temperature was too low or baking time was too short",
        "prevention": "Ensure oven is properly calibrated and check for the correct jiggle cue before turning off the heat",
        "fix": "If discovered after chilling, freeze the cheesecake to serve it as a frozen dessert"
      }
    ],
    "chef_notes": [
      "Squeeze the gulab jamuns gently to remove excess syrup before halving. This critical step prevents the heavy syrup from weeping into the cheesecake batter and altering the dense, creamy texture.",
      "Ensure your cream cheese is completely at room temperature before beating. Cold cream cheese will inevitably result in small, stubborn lumps that ruin the mouthfeel.",
      "Using an eggless base with condensed milk not only honors traditional Indian vegetarian dietary preferences but also provides a fudge-like density that pairs beautifully with the spongy gulab jamuns.",
      "To cut clean, professional slices, dip a sharp knife in a tall container of hot water, wipe it completely dry with a towel, and make your cut. Repeat this process for every single slice."
    ],
    "cultural_context": "Gulab jamun is one of South Asia's most beloved sweets, consisting of deep-fried milk solid dumplings soaked in a fragrant sugar syrup infused with rose and cardamom. By embedding these tender dumplings into a Western-style baked cheesecake, this dessert beautifully bridges culinary traditions. The fusion has become immensely popular during Diwali and modern Indian weddings, representing a globalized approach to festive celebrations.",
