    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Prepare all vegetables by dicing the onion, carrots, celery, and zucchini into uniform, bite-sized pieces to ensure even cooking.",
        "structured": {
          "action": "CHOP",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "cook",
        "text": "Heat the extra virgin olive oil in a large pot or Dutch oven over medium heat. Add the diced onion, carrots, and celery. Sauté until the vegetables are softened and the onions are translucent, about 7 to 8 minutes.",
        "structured": {
          "action": "SAUTÉ",
          "temperature": null,
          "duration": "PT8M",
          "doneness_cues": {
            "visual": "Onions are translucent and vegetables are slightly softened but not browned",
            "tactile": "Carrots yield slightly when pressed with a wooden spoon"
          }
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "cook",
        "text": "Stir in the minced garlic, dried oregano, and dried basil. Cook for 1 minute until highly fragrant, stirring continuously to prevent the garlic from burning.",
        "structured": {
          "action": "SAUTÉ",
          "temperature": null,
          "duration": "PT1M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "cook",
        "text": "Pour in the crushed tomatoes and vegetable broth. Increase the heat to medium-high to bring the liquid to a gentle boil around 100°C/212°F, then immediately reduce the heat to low to maintain a steady simmer.",
        "structured": {
          "action": "BOIL",
          "temperature": {
            "celsius": 100,
            "fahrenheit": 212
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "cook",
        "text": "Add the diced zucchini, green beans, kosher salt, and black pepper. Cover the pot partially and simmer for 15 minutes, allowing the flavors to meld and the vegetables to become tender.",
        "structured": {
          "action": "SIMMER",
          "temperature": null,
          "duration": "PT15M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "cook",
        "text": "Stir in the drained cannellini beans and the dry small pasta. Continue to simmer uncovered for another 10 to 12 minutes, stirring occasionally, until the pasta is cooked al dente.",
        "structured": {
          "action": "SIMMER",
          "temperature": null,
          "duration": "PT12M",
          "doneness_cues": {
            "visual": "Pasta is fully hydrated and swollen",
            "tactile": "Pasta offers slight resistance when bitten, vegetables are completely tender"
          }
        },
        "tips": []
      },
      {
        "step_number": 7,
        "phase": "finish",
        "text": "Remove the pot from the heat. Taste the broth and adjust the seasoning with more salt or pepper if necessary. Ladle into warm bowls and top with a sprinkle of grated vegetarian hard cheese if desired.",
        "structured": {
          "action": "SERVE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Soup becomes too thick and pasta is mushy",
        "likely_cause": "The pasta was cooked directly in the soup and left to sit, absorbing the broth as it rested.",
        "prevention": "If making ahead of time or expecting leftovers, cook the pasta in a separate pot of boiling salted water and add it to individual serving bowls instead of the main pot.",
        "fix": "Stir in additional warm vegetable broth or water a little at a time until the desired soup consistency is reached."
      },
      {
        "symptom": "Vegetables are unevenly cooked",
        "likely_cause": "Vegetables were cut into drastically different sizes, causing smaller pieces to turn to mush while larger pieces remained crunchy.",
        "prevention": "Take time during the prep phase to dice the carrots, celery, onion, and zucchini into uniform pieces.",
        "fix": "Cannot be fixed once cooked, but simmering slightly longer may soften the hard pieces at the expense of the softer ones."
      }
    ],
    "chef_notes": [
      "Minestrone is a clean-out-the-fridge soup; feel free to swap in seasonal vegetables like butternut squash or kale in the winter, or asparagus and peas in the spring.",
      "If you have a leftover rind of vegetarian parmesan-style cheese, drop it into the soup during the simmering phase. It acts as an umami bomb and adds incredible depth to the broth. Remember to fish it out before serving.",
      "For a brighter finish, stir in a teaspoon of fresh lemon juice or a splash of red wine vinegar right before serving to elevate the rich tomato flavor.",
      "Rinsing canned beans thoroughly is crucial. The packing liquid is starchy and contains excess sodium, which can make the soup broth murky and overly salty."
    ],
    "cultural_context": "Minestrone translates roughly to big soup in Italian, historically rooted in the rural peasant tradition of cucina povera. It was traditionally prepared to utilize leftover vegetables, legumes, and whatever was abundantly growing in the garden. Because there is no fixed, authoritative recipe for minestrone, it beautifully reflects the changing seasons and diverse regional agricultural landscapes of Italy.",
