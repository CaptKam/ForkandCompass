    "instructions": [
      {
        "step_number": 1,
        "phase": "cook",
        "text": "Preheat a grill or heavy grill pan over medium-high heat, reaching approximately 200C/400F.",
        "structured": {
          "action": "PREHEAT",
          "temperature": {
            "celsius": 200,
            "fahrenheit": 392
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "prep",
        "text": "Using a pastry brush, lightly coat the husked ear of sweet corn with the neutral cooking oil.",
        "structured": {
          "action": "SEASON",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "cook",
        "text": "Place the corn on the hot grill. Cook, turning occasionally, until charred spots appear on all sides and the kernels are tender, about 10 minutes.",
        "structured": {
          "action": "GRILL",
          "temperature": null,
          "duration": "PT10M",
          "doneness_cues": {
            "visual": "Deep brown or black charred spots evenly distributed across the kernels",
            "tactile": "Kernels feel slightly softened when pressed"
          }
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "prep",
        "text": "Remove the corn from the heat and set it aside to cool completely so it does not melt the avocado fat later.",
        "structured": {
          "action": "COOL",
          "temperature": null,
          "duration": "PT10M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "prep",
        "text": "Once cool enough to handle, stand the corn vertically on a cutting board and slice the charred kernels off the cob.",
        "structured": {
          "action": "SLICE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "prep",
        "text": "In a mortar and pestle, combine the white onion, jalapeno pepper, fresh cilantro, and kosher salt. Pound the mixture firmly using a circular grinding motion until it forms a wet, fragrant paste.",
        "structured": {
          "action": "POUND",
          "temperature": null,
          "duration": "PT2M",
          "doneness_cues": {
            "visual": "A green, relatively uniform slurry with released juices",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 7,
        "phase": "prep",
        "text": "Halve the avocados, remove the pits, and score the flesh with a knife. Scoop the scored flesh directly into the mortar containing the aromatic paste.",
        "structured": {
          "action": "SCORE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 8,
        "phase": "assemble",
        "text": "Using a spoon or the pestle, gently crush and mash the avocado into the paste, stopping while there are still distinct, chunky pieces of avocado remaining.",
        "structured": {
          "action": "CRUSH",
          "temperature": null,
          "duration": null,
          "doneness_cues": {
            "visual": "Cohesive but chunky mixture, not totally smooth",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 9,
        "phase": "assemble",
        "text": "Gently fold in the cooled charred corn kernels, fresh lime juice, and about 40g of the crumbled Cotija cheese, reserving a small amount of cheese for the final presentation.",
        "structured": {
          "action": "FOLD",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 10,
        "phase": "finish",
        "text": "Transfer the guacamole to a serving bowl. Garnish with the reserved Cotija cheese and a dusting of chili powder if desired, then serve immediately.",
        "structured": {
          "action": "GARNISH",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Guacamole turns brown quickly",
        "likely_cause": "The avocado flesh oxidized from exposure to air",
        "prevention": "Mix in enough lime juice and store with plastic wrap pressed flush against the surface of the dip",
        "fix": "Skim off the top browned layer with a spoon; the vibrant green guacamole underneath is perfectly safe to eat"
      },
      {
        "symptom": "Guacamole tastes flat or dull",
        "likely_cause": "Insufficient salt or acid, or aromatics were just chopped instead of pounded",
        "prevention": "Always pound the aromatics with coarse salt to draw out flavorful essential oils",
        "fix": "Stir in an extra splash of lime juice and a pinch of salt to taste"
      }
    ],
    "chef_notes": [
      "Pounding the aromatics (onion, chili, cilantro) with salt breaks down cell walls, releasing vibrant essential oils that simply chopping cannot achieve.",
      "Allow the charred corn to cool completely before folding it into the avocado to prevent the heat from melting the fat and ruining the guacamole's texture.",
      "Cotija is a salty cheese; taste your guacamole before adding any extra salt beyond what is used to pound the aromatics.",
      "If a mortar and pestle are unavailable, mince the aromatics finely, sprinkle with the salt, and use the flat side of a chef's knife to scrape and mash them into a paste directly on your cutting board."
    ],
    "cultural_context": "Guacamole dates back to the Aztec empire in Mesoamerica, where ahuacamolli literally translated to avocado sauce. Utilizing a molcajete (a traditional volcanic stone mortar) is the historically authentic method for its preparation. The addition of charred sweet corn and salty Cotija cheese channels the beloved flavors of Mexican street corn (esquites), marrying two iconic culinary traditions in a single dish.",
