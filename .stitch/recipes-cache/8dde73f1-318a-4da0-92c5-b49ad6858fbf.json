    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Season the chicken thighs evenly with salt and black pepper.",
        "structured": {
          "action": "SEASON",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "cook",
        "text": "Heat vegetable oil in a soup pot over medium-high heat (190°C/375°F). Sear the chicken thighs for 4 minutes per side, adjusting heat to prevent excessive browning.",
        "structured": {
          "action": "SEAR",
          "temperature": {
            "celsius": 190,
            "fahrenheit": 374
          },
          "duration": "PT8M",
          "doneness_cues": {
            "visual": "Chicken should be opaque and lightly browned on the surface.",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "cook",
        "text": "Add minced garlic and grated ginger to the pot. Sauté for 1 minute until fragrant.",
        "structured": {
          "action": "SAUTÉ",
          "temperature": null,
          "duration": "PT1M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "cook",
        "text": "Stir in the mirin, sugar, tamari, and water.",
        "structured": {
          "action": "MIX",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "cook",
        "text": "Bring the liquid to a boil, then reduce heat and simmer gently for 20 minutes until the chicken reaches an internal temperature of 74°C/165°F.",
        "structured": {
          "action": "SIMMER",
          "temperature": {
            "celsius": 90,
            "fahrenheit": 194
          },
          "duration": "PT20M",
          "doneness_cues": {
            "visual": "Liquid should have small, lazy bubbles.",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "cook",
        "text": "In a separate saucepan, boil the soba noodles until al dente according to package directions. Drain and rinse with cool water.",
        "structured": {
          "action": "BOIL",
          "temperature": {
            "celsius": 100,
            "fahrenheit": 212
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 7,
        "phase": "cook",
        "text": "In a small pot of boiling water, blanch the diced leeks and trimmed sugar snap peas for 1 minute. Drain and rinse with cool water.",
        "structured": {
          "action": "BLANCH",
          "temperature": {
            "celsius": 100,
            "fahrenheit": 212
          },
          "duration": "PT1M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 8,
        "phase": "prep",
        "text": "Remove the chicken from the soup pot and cut into 1.5 cm (1/2 inch) pieces.",
        "structured": {
          "action": "CHOP",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 9,
        "phase": "finish",
        "text": "Whisk the miso in a small bowl with a small amount of warm broth (60°C/140°F) until the mixture is smooth.",
        "structured": {
          "action": "TEMPER",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 10,
        "phase": "finish",
        "text": "Return the chopped chicken to the soup pot. Stir in the miso mixture, baby spinach, blanched leeks, and snap peas. Heat for 1 minute until the spinach is wilted.",
        "structured": {
          "action": "STIR",
          "temperature": null,
          "duration": "PT1M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 11,
        "phase": "finish",
        "text": "Place the cooked soba noodles into bowls. Ladle the hot soup over the noodles and garnish with julienned basil.",
        "structured": {
          "action": "SERVE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
