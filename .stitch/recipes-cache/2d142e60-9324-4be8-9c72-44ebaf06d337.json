    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Preheat the oven to 160C/320F for braising the pork. In a small bowl, combine the cumin, coriander, kosher salt, and black pepper. Toss the pork shoulder chunks in the spice blend until thoroughly coated.",
        "structured": {
          "action": "PREHEAT",
          "temperature": {
            "celsius": 160,
            "fahrenheit": 320
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "cook",
        "text": "Heat the olive oil in a large Dutch oven over medium-high heat. Add the spiced pork chunks in batches to avoid crowding, searing until deeply browned on all sides.",
        "structured": {
          "action": "SEAR",
          "temperature": null,
          "duration": "PT15M",
          "doneness_cues": {
            "visual": "Deep golden-brown crust on all sides",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "cook",
        "text": "Return all pork to the Dutch oven. Pour in the chicken broth and the first measure of lime juice, scraping up any browned bits from the bottom. Cover with a heavy lid, transfer to the 160C/320F oven, and braise until the pork yields entirely to a fork.",
        "structured": {
          "action": "BRAISE",
          "temperature": {
            "celsius": 160,
            "fahrenheit": 320
          },
          "duration": "PT2H30M",
          "doneness_cues": {
            "visual": null,
            "tactile": "Meat shreds with zero resistance when pulled with a fork"
          }
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "prep",
        "text": "Remove the pot from the oven and carefully transfer the pork to a cutting board. Shred the meat using two forks. Skim excess fat from the braising liquid, then return the shredded pork to the juices to keep it moist. Increase the oven temperature to 200C/400F.",
        "structured": {
          "action": "SHRED",
          "temperature": {
            "celsius": 200,
            "fahrenheit": 392
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "prep",
        "text": "While the oven preheats, whisk together the sour cream, the second measure of lime juice, lime zest, and salt in a small mixing bowl. Set aside in the refrigerator to allow flavors to meld.",
        "structured": {
          "action": "MIX",
          "temperature": null,
          "duration": "PT5M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "assemble",
        "text": "Arrange half of the tortilla chips in a slightly overlapping layer on a large baking sheet. Top evenly with half of the drained shredded pork and half of the grated cheddar cheese. Repeat with a second layer of chips, the remaining pork, and the remaining cheese.",
        "structured": {
          "action": "ASSEMBLE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 7,
        "phase": "cook",
        "text": "Bake the assembled nachos in the 200C/400F oven until the cheese is completely melted, bubbling, and just starting to brown at the edges.",
        "structured": {
          "action": "BAKE",
          "temperature": {
            "celsius": 200,
            "fahrenheit": 392
          },
          "duration": "PT8M",
          "doneness_cues": {
            "visual": "Cheese is melted, glossy, and bubbling rapidly",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 8,
        "phase": "finish",
        "text": "Remove the nachos from the oven. Immediately scatter the sliced radishes, scallions, and chopped cilantro over the hot cheese. Generously drizzle or dollop the chilled lime crema across the entire platter. Serve immediately.",
        "structured": {
          "action": "GARNISH",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Soggy tortilla chips at the bottom of the platter",
        "likely_cause": "Pork was not drained sufficiently before layering, or chips were too thin to support the heavy toppings.",
        "prevention": "Use only thick, restaurant-style corn tortilla chips and use tongs to slightly drain the pork as you transfer it to the chips.",
        "fix": "Cannot be fixed once fully saturated, but baking an extra 3 minutes can crisp the exposed edges."
      },
      {
        "symptom": "Cheese is clumpy and sweating oil rather than melting smoothly",
        "likely_cause": "Using pre-shredded bagged cheese which contains anti-caking starches.",
        "prevention": "Always grate cheddar cheese from a solid block for melting applications.",
        "fix": "Cannot be fixed"
      }
    ],
    "chef_notes": [
      "Always grate block cheddar yourself. Pre-shredded cheese is coated in cellulose to prevent clumping in the bag, which acts as a barrier to smooth, creamy melting.",
      "For a truly remarkable texture contrast, spread the shredded pork on a bare baking sheet and broil it for 3-5 minutes before adding it to the nachos. This mimics traditional crispy carnitas.",
      "Shock the sliced radishes in a bowl of ice water for 10 minutes while the nachos bake. This maximizes their crisp, refreshing crunch against the rich, fatty pork.",
      "Layering is crucial. A double-layer approach ensures that every chip receives topping, preventing the dreaded dry chip phenomenon found at the bottom of poorly structured nacho mountains."
    ],
    "cultural_context": "Nachos originated in Piedras Negras, Mexico, in 1943, created out of necessity by maitre d' Ignacio 'Nacho' Anaya for a group of hungry visitors. This robust winter iteration builds upon that classic foundation by integrating flavor profiles reminiscent of carnitas, celebrating the rich Mexican tradition of slow-cooked, heavily spiced pork shoulder. The careful balance of rich, fatty meat cut by bright citrus, sharp radishes, and cooling dairy is a hallmark of traditional Mexican culinary architecture.",
