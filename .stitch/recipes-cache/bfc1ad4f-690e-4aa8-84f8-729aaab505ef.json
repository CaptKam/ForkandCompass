    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Halve the avocados, remove the pits, and scoop the flesh into a medium mixing bowl. Use a fork to crush the avocado until mostly smooth but still retaining some small chunks.",
        "structured": {
          "action": "CRUSH",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "prep",
        "text": "Add the finely diced jalapeno, red onion, chopped cilantro, lime juice, and salt to the crushed avocado. Stir thoroughly to combine into a thick guacamole.",
        "structured": {
          "action": "MIX",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "prep",
        "text": "Line a baking sheet with parchment paper. Using a small cookie scoop, shape the guacamole into 20 bite-sized mounds, placing them evenly on the prepared sheet.",
        "structured": {
          "action": "SHAPE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "prep",
        "text": "Transfer the baking sheet to the freezer. Freeze the guacamole mounds until completely solid, which will take about 2 hours.",
        "structured": {
          "action": "FREEZE",
          "temperature": null,
          "duration": "PT2H",
          "doneness_cues": {
            "visual": null,
            "tactile": "Rock hard to the touch"
          }
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "cook",
        "text": "Add the neutral oil to a heavy-bottomed pot, ensuring it is at least 5 centimeters deep. Heat the oil to 190 degrees Celsius (375 degrees Fahrenheit).",
        "structured": {
          "action": "PREHEAT",
          "temperature": {
            "celsius": 190,
            "fahrenheit": 374
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "prep",
        "text": "Just before frying, prepare the batter. In a bowl, whisk together the fine corn flour, baking powder, and salt. Pour in the ice cold seltzer water and whisk lightly until just combined. Lumps are acceptable.",
        "structured": {
          "action": "WHISK",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 7,
        "phase": "cook",
        "text": "Working in batches of 4 or 5, dip the frozen guacamole scoops into the batter, ensuring they are fully coated. Immediately drop them into the hot oil. Fry for 90 seconds to 2 minutes until the exterior is golden and crispy, but the center remains cool.",
        "structured": {
          "action": "FRY",
          "temperature": {
            "celsius": 190,
            "fahrenheit": 374
          },
          "duration": "PT2M",
          "doneness_cues": {
            "visual": "Crispy and golden yellow",
            "tactile": null
          }
        },
        "tips": [
          "Do not overcook, or the guacamole will melt and leak out of the batter.",
          "Ensure the oil returns to 190 degrees Celsius between batches."
        ]
      },
      {
        "step_number": 8,
        "phase": "finish",
        "text": "Use a spider skimmer to carefully remove the fried bites from the oil. Transfer them to a wire cooling rack set over paper towels to drain excess oil.",
        "structured": {
          "action": "DRAIN",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 9,
        "phase": "finish",
        "text": "Serve immediately while the outer shell is hot and the inside is still creamy and cold.",
        "structured": {
          "action": "SERVE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Guacamole melts and leaks into the frying oil",
        "likely_cause": "The guacamole scoops were not frozen entirely solid, or the frying oil temperature was too low.",
        "prevention": "Freeze the guacamole scoops for at least 2 full hours. Maintain frying oil at 190C to ensure rapid crisping.",
        "fix": "Cannot be fixed"
      },
      {
        "symptom": "Batter is too thick and heavy",
        "likely_cause": "Corn flour to liquid ratio was off, or batter was overmixed.",
        "prevention": "Measure the flour by weight, not volume. Do not overmix the batter; small lumps are fine.",
        "fix": "Stir an additional tablespoon of cold seltzer water into the batter until thinned."
      }
    ],
    "chef_notes": [
      "The secret to a cool interior and hot exterior is flash-frying. Because the core is frozen solid, a rapid deep fry perfectly cooks the batter before the heat penetrates the center.",
      "Carbonation in the seltzer water expands rapidly when it hits hot oil, creating a highly aerated, shatteringly crisp coating that pairs wonderfully with creamy avocado.",
      "Keeping the batter ice cold prevents gluten or starch development, yielding a lighter, crispier crust.",
      "Ensure your oil has a high smoke point and a neutral flavor so it does not compete with the delicate taste of the fresh guacamole."
    ],
    "cultural_context": "While guacamole has ancient Mesoamerican roots dating back to the Aztecs, deep-frying it is a distinctly modern, playful fusion technique. It brings the beloved flavors of Mexican cuisine into the realm of state-fair style textural exploration.",
