    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Place the sushi rice in a fine mesh sieve and rinse thoroughly under cold running water until the water runs completely clear. Drain well.",
        "structured": {
          "action": "STRAIN",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "cook",
        "text": "Combine the rinsed rice and water in a saucepan. Bring to a boil at 100°C/212°F over medium-high heat. Immediately reduce the heat to the lowest setting, cover tightly, and simmer for 15 minutes. Remove from heat and let sit covered for 10 minutes.",
        "structured": {
          "action": "SIMMER",
          "temperature": {
            "celsius": 100,
            "fahrenheit": 212
          },
          "duration": "PT25M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "prep",
        "text": "Transfer the cooked rice to a wide mixing bowl. Gently fold in the rice vinegar, sugar, and salt while fanning the rice to cool it down to body temperature, approximately 37°C/98°F.",
        "structured": {
          "action": "FOLD",
          "temperature": {
            "celsius": 37,
            "fahrenheit": 99
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "prep",
        "text": "In a small bowl, whisk together the mayonnaise and sriracha sauce until smooth and uniform in color. Set aside.",
        "structured": {
          "action": "WHISK",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "prep",
        "text": "In a medium bowl, combine the diced sushi-grade salmon and tuna. Add the soy sauce, toasted sesame oil, and mirin. Toss gently to coat and allow the fish to marinate for 5 to 10 minutes.",
        "structured": {
          "action": "MARINATE",
          "temperature": null,
          "duration": "PT10M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "assemble",
        "text": "Divide the seasoned sushi rice between two bowls. Arrange the marinated fish, shelled edamame, diced mango, and sliced avocado in distinct sections over the rice. Drizzle generously with the spicy sriracha mayonnaise and garnish with shredded nori seaweed and toasted sesame seeds.",
        "structured": {
          "action": "ASSEMBLE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Rice is gummy or mushy",
        "likely_cause": "Rice was not rinsed enough, leaving excess starch, or too much water was added",
        "prevention": "Always rinse sushi rice until water runs clear and measure water accurately",
        "fix": "Spread the warm rice thinly on a baking sheet to let excess moisture evaporate; texture cannot be fully restored"
      },
      {
        "symptom": "Fish texture becomes tough or mushy",
        "likely_cause": "Fish was left in the soy sauce marinade for too long, causing it to cure",
        "prevention": "Do not marinate fish for more than 15 minutes before serving",
        "fix": "Cannot be fixed"
      }
    ],
    "chef_notes": [
      "Always source fish specifically labeled as sushi-grade or sashimi-grade from a reputable fishmonger. This ensures it has been properly flash-frozen to eliminate parasites.",
      "For the glossiest, most authentic sushi rice, fan the rice vigorously while folding in the vinegar dressing. This rapidly cools the exterior of the grains and produces a beautiful shine.",
      "A small squeeze of fresh lime juice or yuzu juice over the marinated fish just before serving can add a bright, acidic note that perfectly cuts through the richness of the salmon and spicy mayonnaise.",
      "Keep raw fish refrigerated right up until you are ready to assemble the bowls. Warm raw fish compromises both food safety and the delicate texture of the dish."
    ],
    "cultural_context": "Poke, which translates to to slice or to cut crosswise in Hawaiian, originated as a humble fisherman's snack made from off-cuts of the day's catch seasoned with sea salt and local seaweed. With the influx of Japanese immigrants to Hawaii, ingredients like soy sauce and sesame oil were integrated, eventually evolving into the modern, internationally beloved poke bowl served over sushi rice.",
