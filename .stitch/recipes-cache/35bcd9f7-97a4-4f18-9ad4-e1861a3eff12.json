    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Wrap the tofu in paper towels and press using a tofu press or heavy objects for 15 minutes to extract excess moisture. Cut into bite-sized cubes.",
        "structured": {
          "action": "PRESS",
          "temperature": null,
          "duration": "PT15M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "prep",
        "text": "Place the cubed tofu in a mixing bowl and sprinkle with cornstarch. Toss gently until every piece is evenly coated.",
        "structured": {
          "action": "DREDGE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "prep",
        "text": "In a small bowl, whisk together the soy sauce, vegetarian mushroom oyster sauce, water, sugar, and toasted sesame oil to create the sauce.",
        "structured": {
          "action": "WHISK",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "cook",
        "text": "Heat 20ml of the vegetable oil in a wok or large skillet over medium-high heat. Add the coated tofu cubes in a single layer. Pan-fry for 6 to 8 minutes, turning occasionally, until crispy and golden brown on all sides. Remove the tofu from the pan and set aside.",
        "structured": {
          "action": "FRY",
          "temperature": null,
          "duration": "PT8M",
          "doneness_cues": {
            "visual": "Crispy, golden brown crust on all sides",
            "tactile": "Firm exterior shell"
          }
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "cook",
        "text": "Add the remaining 10ml of vegetable oil to the wok. Add the minced garlic, grated ginger, and sliced chilies. Sauté for 30 seconds until highly fragrant, being careful not to burn the garlic.",
        "structured": {
          "action": "SAUTÉ",
          "temperature": null,
          "duration": "PT30S",
          "doneness_cues": {
            "visual": "Garlic taking on a very light golden hue",
            "tactile": "Aromatics softening slightly"
          }
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "cook",
        "text": "Add the shelled edamame to the wok and stir-fry for 2 minutes to warm through and coat in the aromatics.",
        "structured": {
          "action": "STIR",
          "temperature": null,
          "duration": "PT2M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 7,
        "phase": "assemble",
        "text": "Return the crispy tofu to the wok. Pour the prepared sauce mixture over the ingredients. Toss vigorously for 1 minute as the sauce bubbles and thickens, clinging to the tofu and edamame.",
        "structured": {
          "action": "MIX",
          "temperature": null,
          "duration": "PT1M",
          "doneness_cues": {
            "visual": "Sauce reduces to a glossy, sticky glaze",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 8,
        "phase": "finish",
        "text": "Remove from heat. Transfer to a serving platter and garnish with thinly sliced scallions and toasted sesame seeds.",
        "structured": {
          "action": "GARNISH",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Tofu is mushy and sticking to the pan",
        "likely_cause": "Insufficient pressing time or adding tofu before the oil was fully heated",
        "prevention": "Ensure tofu is pressed thoroughly and oil is shimmering before frying. Do not crowd the pan.",
        "fix": "Add a splash more oil, turn the heat up slightly, and avoid moving the tofu until a crust forms."
      },
      {
        "symptom": "Sauce is too watery and pooling at the bottom",
        "likely_cause": "Residual cornstarch on the tofu was insufficient to thicken the sauce, or not cooked long enough",
        "prevention": "Ensure tofu is well-coated in cornstarch.",
        "fix": "Mix 5g of cornstarch with 10ml of cold water to make a slurry, pour it into the pan, and simmer for 30 seconds until thick."
      },
      {
        "symptom": "Garlic tastes bitter",
        "likely_cause": "Wok was too hot and aromatics burned during the initial saute",
        "prevention": "Lower the heat slightly before adding aromatics and keep them moving continuously.",
        "fix": "Cannot be fixed. If caught early, wipe the pan and restart the aromatics step."
      }
    ],
    "chef_notes": [
      "For the crispiest tofu, resist the urge to move the cubes immediately after they hit the pan. Let them sit undisturbed for 1-2 minutes per side so a proper crust can form.",
      "If using frozen edamame, briefly blanch them in boiling water for one minute, then drain thoroughly before adding them to the wok to prevent excess water from diluting the sauce.",
      "Cornstarch is essential not just for a crispy exterior, but because the residual starch left on the tofu helps thicken the sauce when it is added at the end.",
      "To adjust the heat level cleanly, rely on the seeds of the bird's eye chilies. Keep them in for maximum heat, or scrape them out before slicing for a milder chili flavor."
    ],
    "cultural_context": "Stir-frying is a fundamental Chinese cooking technique that relies on high heat and minimal liquid to quickly sear ingredients, preserving their texture and vibrant color. This modern fusion dish combines the classic Chinese method of shallow-frying cornstarch-coated tofu with edamame, a staple ingredient in Japanese cuisine. The resulting dish celebrates the versatility of soy in both its fermented and whole-bean forms.",
