    "troubleshooting": [
      {
        "symptom": "Guacamole turns brown quickly",
        "likely_cause": "Oxidation from exposure to air",
        "prevention": "Add sufficient lime juice during preparation and press plastic wrap directly onto the surface of the guacamole when storing",
        "fix": "Scrape off the top brown layer; the bright green guacamole underneath is perfectly safe to eat"
      },
      {
        "symptom": "Guacamole is too spicy",
        "likely_cause": "Jalapeño seeds and ribs were included, or the pepper was exceptionally hot",
        "prevention": "Remove all seeds and inner white membranes from the jalapeño before dicing",
        "fix": "Mash in an extra half of an avocado to dilute the heat"
      }
    ],
    "chef_notes": [
      "Always use Hass avocados for the best creamy texture and rich flavor. They should yield slightly to gentle pressure at the stem.",
      "Adding the lime juice immediately over the scooped avocado helps prevent oxidation while you prepare the other ingredients.",
      "Rolling the lime firmly on the counter before cutting helps break the internal cell walls, yielding significantly more juice.",
      "For the best texture, avoid over-mashing. Authentic guacamole should have distinct, creamy chunks of avocado rather than a smooth, pureed consistency."
    ],
    "cultural_context": "Guacamole dates back to the Aztec Empire in Central America, where avocados naturally grow. The name originates from the Nahuatl word ahuacamolli, which translates directly to avocado sauce.",
