    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "In a mixing bowl, combine the flour, ajwain seeds, and salt. Add the melted ghee and rub the mixture between your fingers until it resembles coarse breadcrumbs. Gradually add cold water and knead into a stiff, firm dough.",
        "structured": {
          "action": "KNEAD",
          "temperature": null,
          "duration": "PT10M",
          "doneness_cues": {
            "visual": null,
            "tactile": "stiff, firm, and slightly rough rather than perfectly smooth"
          }
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "prep",
        "text": "Cover the dough tightly with a damp cloth and allow it to rest at room temperature.",
        "structured": {
          "action": "REST",
          "temperature": null,
          "duration": "PT30M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "cook",
        "text": "Heat 15ml of vegetable oil in a pan over medium heat. Add the cumin seeds and crushed coriander seeds, cooking until they sizzle and release their aroma.",
        "structured": {
          "action": "SAUTÉ",
          "temperature": null,
          "duration": "PT1M",
          "doneness_cues": {
            "visual": "seeds are spluttering and lightly browned",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "cook",
        "text": "Add the grated ginger, green chili, and peas to the pan. Cook for 2 minutes. Stir in the roughly mashed potatoes, garam masala, amchur powder, and salt. Mix thoroughly to combine the flavors.",
        "structured": {
          "action": "STIR",
          "temperature": null,
          "duration": "PT5M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "prep",
        "text": "Remove the filling from the heat and spread it out on a plate to cool completely before assembling the samosas.",
        "structured": {
          "action": "COOL",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "prep",
        "text": "Place the mint leaves, coriander leaves, green chili, ginger, lemon juice, roasted cumin powder, salt, and water into a blender. Process until a smooth, vibrant green chutney forms. Transfer to a bowl.",
        "structured": {
          "action": "BLEND",
          "temperature": null,
          "duration": "PT3M",
          "doneness_cues": {
            "visual": "smooth, vibrant green liquid with no large leafy chunks",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 7,
        "phase": "assemble",
        "text": "Divide the rested dough into 6 equal portions. Roll each portion into a smooth ball, then flatten and roll out into a thin oval shape, about 15cm long. Cut each oval in half horizontally to create two semi-circles.",
        "structured": {
          "action": "ROLL",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 8,
        "phase": "assemble",
        "text": "Take a semi-circle, lightly brush the straight edge with water, and fold it into a cone shape, overlapping the straight edge to seal. Fill the cone with 2 tablespoons of the cooled potato filling, brush the open top edge with water, and pinch firmly to close.",
        "structured": {
          "action": "ASSEMBLE",
          "temperature": null,
          "duration": null,
          "doneness_cues": {
            "visual": "a tightly sealed triangular pyramid",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 9,
        "phase": "finish",
        "text": "Heat the deep frying oil in a heavy-bottomed pot to 160C/320F. Carefully slide the samosas into the warm oil and fry on a low to medium heat, turning occasionally, until perfectly crisp and golden brown.",
        "structured": {
          "action": "FRY",
          "temperature": {
            "celsius": 160,
            "fahrenheit": 320
          },
          "duration": "PT12M",
          "doneness_cues": {
            "visual": "even, deep golden brown exterior without excessive blistering",
            "tactile": "hard, crispy casing"
          }
        },
        "tips": [
          "Do not crowd the pot; fry in batches of 4 to 5 depending on pan size.",
          "Low and slow frying is essential to cook the thick folded edges of the pastry."
        ]
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Small blisters and bubbles covering the entire surface of the pastry after frying.",
        "likely_cause": "The frying oil was too hot when the samosas were dropped in.",
        "prevention": "Ensure the oil is warm (160C), not smoking hot. The samosas should take several minutes to color.",
        "fix": "Lower the heat immediately for the current batch. Ensure oil cools slightly before adding the next batch."
      },
      {
        "symptom": "Samosas break open or leak filling into the oil.",
        "likely_cause": "Edges were not sealed tightly enough, or the filling was overstuffed.",
        "prevention": "Use a dab of water along the seam and pinch firmly. Leave a small gap at the top of the cone before sealing.",
        "fix": "Cannot be fixed once in the oil. Remove the broken samosa quickly with a slotted spoon to prevent burned filling in the oil."
      }
    ],
    "chef_notes": [
      "The process of rubbing fat into the flour is called moyan. It coats the gluten strands and is the absolute non-negotiable secret to a flaky, short pastry crust.",
      "A stiff dough absorbs less oil during frying. Resist the temptation to add extra water during the kneading phase.",
      "Do not over-mash the potatoes. Leaving distinct chunks adds wonderful textural contrast to the final filling.",
      "Frying must be an exercise in patience. Starting the samosas in warm oil and slowly raising the heat ensures a perfectly crisp crust that remains crunchy long after cooling."
    ],
    "cultural_context": "The samosa traces its ancient origins to the Middle Eastern sambusak, traveling to the Indian subcontinent along trade routes with merchants and rulers. Today, this spiced potato and pea iteration stands as a beloved culinary icon of India, representing a masterful amalgamation of indigenous spices and the potato, which was introduced by Portuguese traders in the 17th century.",
