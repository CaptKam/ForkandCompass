    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Core and carefully dice the roma tomatoes into small, even 1cm cubes using a serrated knife.",
        "structured": {
          "action": "DICE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "prep",
        "text": "Toss the diced tomatoes with kosher salt and place them in a colander set over a mixing bowl. Let drain for 15 minutes to remove excess liquid.",
        "structured": {
          "action": "DRAIN",
          "temperature": null,
          "duration": "PT15M",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "prep",
        "text": "Discard the extracted tomato juice. In a clean mixing bowl, gently combine the drained tomatoes with minced garlic, fresh basil, 30ml extra-virgin olive oil, optional balsamic vinegar, and black pepper.",
        "structured": {
          "action": "MIX",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 4,
        "phase": "prep",
        "text": "Slice the rustic sourdough loaf into 1.5cm thick slices on a cutting board.",
        "structured": {
          "action": "SLICE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "prep",
        "text": "Brush both sides of each bread slice lightly with the remaining 30ml of extra-virgin olive oil.",
        "structured": {
          "action": "SEASON",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "cook",
        "text": "Heat a grill pan over medium-high heat around 200°C/400°F. Toast the oiled bread slices until crisp and golden brown with distinct char marks, about 2 minutes per side.",
        "structured": {
          "action": "GRILL",
          "temperature": {
            "celsius": 200,
            "fahrenheit": 392
          },
          "duration": "PT4M",
          "doneness_cues": {
            "visual": "Golden brown with distinct, dark char marks on the edges",
            "tactile": "Completely crisp and firm to the touch"
          }
        },
        "tips": []
      },
      {
        "step_number": 7,
        "phase": "finish",
        "text": "Immediately after removing the hot bread from the grill pan, gently rub one side of each slice with the cut side of the halved raw garlic clove.",
        "structured": {
          "action": "SEASON",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 8,
        "phase": "assemble",
        "text": "Spoon the marinated tomato topping generously over the garlic-rubbed side of the grilled bread slices.",
        "structured": {
          "action": "ASSEMBLE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 9,
        "phase": "finish",
        "text": "Serve immediately before the bread loses its crunch, garnished with extra fresh basil leaves if desired.",
        "structured": {
          "action": "SERVE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Bread becomes soggy immediately upon assembly",
        "likely_cause": "Tomato mixture retained too much water or the bread was under-toasted",
        "prevention": "Ensure tomatoes are salted and thoroughly drained before mixing, and toast bread until completely crisp throughout.",
        "fix": "Cannot be fixed once assembled."
      }
    ],
    "chef_notes": [
      "Using room-temperature, in-season tomatoes is non-negotiable for this dish; never refrigerate your tomatoes before preparation as it degrades their flavor and texture.",
      "Salting and draining the tomatoes removes excess water, concentrating their natural sweetness and preventing the bread from becoming instantly waterlogged.",
      "Rubbing raw garlic on the hot, toasted bread acts like a microplane grater, melting the pungent garlic oils directly into the crumb without overwhelming the palate."
    ],
    "cultural_context": "Bruschetta originates from 15th century Italy, tracing back to Ancient Rome where olive growers would bring their harvest to a local press and taste a sample of their freshly pressed oil on a slice of bread. The name derives from the Roman dialect verb bruscare, meaning to roast over coals.",
