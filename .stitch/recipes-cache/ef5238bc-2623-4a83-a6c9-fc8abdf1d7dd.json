    "instructions": [
      {
        "step_number": 1,
        "phase": "prep",
        "text": "Combine the freshly brewed espresso and Marsala wine in a shallow bowl. Set aside to cool completely to room temperature (approx 20°C/68°F).",
        "structured": {
          "action": "MIX",
          "temperature": {
            "celsius": 20,
            "fahrenheit": 68
          },
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 2,
        "phase": "prep",
        "text": "In a large bowl, whisk egg yolks and 50g of sugar until pale yellow, creamy, and doubled in volume. The mixture should fall in ribbons from the whisk.",
        "structured": {
          "action": "WHISK",
          "temperature": null,
          "duration": "PT5M",
          "doneness_cues": {
            "visual": "Pale yellow, ribbon stage",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 3,
        "phase": "prep",
        "text": "Add the mascarpone to the yolk mixture. Whisk gently on low speed or by hand just until combined and smooth. Do not over-beat or the cheese may curdle/split.",
        "structured": {
          "action": "MIX",
          "temperature": null,
          "duration": null,
          "doneness_cues": {
            "visual": "Smooth and homogenous",
            "tactile": null
          }
        },
        "tips": [
          "Mascarpone should be cold when added to prevent splitting."
        ]
      },
      {
        "step_number": 4,
        "phase": "prep",
        "text": "In a separate clean, grease-free bowl, beat the egg whites with a pinch of salt until frothy. Gradually add the remaining 50g of sugar and whip until stiff peaks form.",
        "structured": {
          "action": "WHIP",
          "temperature": null,
          "duration": null,
          "doneness_cues": {
            "visual": "Stiff, glossy peaks",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 5,
        "phase": "prep",
        "text": "Gently fold one-third of the whipped egg whites into the mascarpone mixture to lighten it. Then, carefully fold in the remaining whites until no white streaks remain, keeping as much air in the mixture as possible.",
        "structured": {
          "action": "FOLD",
          "temperature": null,
          "duration": null,
          "doneness_cues": {
            "visual": "Uniform pale cream color, airy texture",
            "tactile": null
          }
        },
        "tips": []
      },
      {
        "step_number": 6,
        "phase": "assemble",
        "text": "Quickly dip each Savoiardi biscuit into the cooled coffee mixture (1 second per side) and arrange them in a single layer at the bottom of the dish. Do not soak them; they should be moist on the outside but still firm in the center.",
        "structured": {
          "action": "DREDGE",
          "temperature": null,
          "duration": "PT2S",
          "doneness_cues": null
        },
        "tips": [
          "If the cookies are too soggy, the tiramisu will collapse."
        ]
      },
      {
        "step_number": 7,
        "phase": "assemble",
        "text": "Spread half of the mascarpone cream mixture evenly over the layer of biscuits.",
        "structured": {
          "action": "ASSEMBLE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 8,
        "phase": "assemble",
        "text": "Repeat with a second layer of dipped biscuits and top with the remaining mascarpone cream. Smooth the top with a spatula.",
        "structured": {
          "action": "ASSEMBLE",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 9,
        "phase": "finish",
        "text": "Cover the dish with plastic wrap and refrigerate for at least 6 hours, preferably overnight, to allow the cream to set and flavors to meld.",
        "structured": {
          "action": "CHILL",
          "temperature": {
            "celsius": 4,
            "fahrenheit": 39
          },
          "duration": "PT6H",
          "doneness_cues": null
        },
        "tips": []
      },
      {
        "step_number": 10,
        "phase": "finish",
        "text": "Just before serving, place cocoa powder in a fine mesh sieve and generously dust the top of the tiramisu.",
        "structured": {
          "action": "GARNISH",
          "temperature": null,
          "duration": null,
          "doneness_cues": null
        },
        "tips": []
      }
    ],
    "troubleshooting": [
      {
        "symptom": "Filling is runny or soupy",
        "likely_cause": "Egg whites were over-mixed or mascarpone was over-beaten causing separation",
        "prevention": "Fold egg whites gently and stop whisking mascarpone as soon as it is combined",
        "fix": "Freeze for 1-2 hours before serving to firm up (texture will be more like semifreddo)"
      },
      {
        "symptom": "Base is watery/leaking liquid",
        "likely_cause": "Ladyfingers were soaked too long",
        "prevention": "Dip cookies very quickly—just 'in and out' of the coffee",
        "fix": "Cannot be fixed"
      }
    ],
    "chef_notes": [
      "Safety First: This authentic recipe uses raw eggs. Ensure you use pasteurized eggs if serving to vulnerable groups (elderly, pregnant, immune-compromised) or cook the yolks with sugar over a bain-marie to 71°C/160°F before mixing.",
      "The soak is the most critical variable. Different brands of Savoiardi absorb liquid at different rates. Test one cookie first; it should be dark on the outside but white in the center when snapped.",
      "Do not use pre-ground coffee if possible. Freshly pulled espresso provides the necessary depth of flavor to cut through the rich cheese.",
      "Allowing the tiramisu to rest overnight drastically improves the flavor and structural integrity, making it easier to slice."
    ],
    "cultural_context": "Tiramisu, meaning 'pick me up' or 'cheer me up' in Italian, is a relatively modern dessert, likely originating in the Veneto region (Treviso) in the 1960s or 1970s. It represents the perfect marriage of Italy's coffee culture with its tradition of rich, dairy-based desserts.",
